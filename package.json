{
  "name": "rapidcam",
  "version": "1.0.0",
  "description": "Web-based parametric 2D vector editor — foundation for a CNC CAM program",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate": "npm run typecheck && npm test && npm run build",
    "clean": "node clean.js"
  },
  "devDependencies": {
    "@types/opentype.js": "^1.3.10",
    "ajv": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "clipper2-ts": "^2.0.1-17",
    "hersheytext": "^2.0.0",
    "opentype.js": "^2.0.0",
    "posthog-js": "^1.383.2"
  },
  "allowScripts": {
    "core-js@3.49.0": true,
    "esbuild@0.28.0": true
  }
}
